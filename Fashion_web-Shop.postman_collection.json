{
  "info": {
    "name": "Fashion_web Shop API",
    "description": "Shop endpoints for Fashion_web (Create supports avatar upload)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Shop",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "My Shop", "type": "text" },
            { "key": "phone", "value": "0123456789", "type": "text" },
            { "key": "typeProvider", "value": "individual", "type": "text" },
            { "key": "desc", "value": "A sample shop", "type": "text" },
            { "key": "avatar_url", "value": "", "type": "text" },
            { "key": "bank", "value": "Bank Name", "type": "text" },
            { "key": "bank_account", "value": "Account Name", "type": "text" },
            { "key": "bank_number", "value": "123456789", "type": "text" },
            { "key": "address", "value": "123 Main St", "type": "text" },
            { "key": "province_id", "value": "province-id", "type": "text" },
            { "key": "district_id", "value": "district-id", "type": "text" },
            { "key": "commune_id", "value": "commune-id", "type": "text" },
            { "key": "avatar", "type": "file", "src": "" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/shop",
          "host": ["{{baseUrl}}"],
          "path": ["shop"]
        }
      },
      "response": []
    },
    {
      "name": "Get All Shops",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/shop?limit={{limit}}&page={{page}}",
          "host": ["{{baseUrl}}"],
          "path": ["shop"],
          "query": [
            { "key": "limit", "value": "{{limit}}" },
            { "key": "page", "value": "{{page}}" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Shop By ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/shop/:id",
          "host": ["{{baseUrl}}"],
          "path": ["shop", ":id"]
        }
      },
      "response": []
    },
    {
      "name": "Update Shop",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated Shop\",\n  \"desc\": \"Updated description\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/shop/:id",
          "host": ["{{baseUrl}}"],
          "path": ["shop", ":id"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Shop",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/shop/:id",
          "host": ["{{baseUrl}}"],
          "path": ["shop", ":id"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "limit", "value": "10", "type": "string" },
    { "key": "page", "value": "1", "type": "string" }
  ]
}
