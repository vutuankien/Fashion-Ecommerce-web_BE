// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role{
  admin
  user
  author
  shop
  employer
}

enum InventoryStatus {
  ACTIVE
  DISABLED
}


enum Level{
  normal
  priority
  vip
}
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  age       Int?
  provider  String
  address   String?
  password  String
  refresh_token String?
  phone     String?
  spend     Int?
  level     Level? @default(normal)
  avatar_url String?
  role      Role  @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /** Khai báo 2 chiều */
  passwordResetTokens PasswordResetToken[]
  shop shop?
  employer Employer?
  wishlist Wishlist[]
  comments comments[]
  /** Quan hệ ngược với Cart */
  carts Cart[]
  //Quan hệ ngược với FollowShop
  FollowShop FollowShop[]
  voucherUsages VoucherUsage[]
}

model Author {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  bio        String?
  avatar_url String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  //khai báo 2 chiều
  posts      Post[]
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  publish   Boolean  @default(false)

  author_id  Int
  author    Author   @relation(fields: [author_id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   // HASH
  user_id    Int
  user      User     @relation(fields: [user_id], references: [id])

  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())
}





model provinces {
  id      String @id
  name    String
  name_en String
  new_id  String
  region_type String
  country_code Int


  warehouses Warehouse[] @relation("WarehouseProvince")
  providers Provider[] @relation("ProviderProvince")
  shops shop[] @relation("ShopProvince")
}

model districts {
  id    String    @id
  name   String
  name_en String
  province_id String

  warehouses Warehouse[] @relation("WarehouseDistrict")
  providers Provider[] @relation("ProviderDistrict")
  shops shop[] @relation("ShopDistrict")
}

model communes{
  id    String  @id
  name   String
  name_en String
  new_id String?
  province_id String
  district_id String


  warehouses Warehouse[] @relation("WarehouseCommune")
  providers Provider[] @relation("ProviderCommune")
  shops shop[] @relation("ShopCommune")
}



model Warehouse {
  id String @id @default(cuid())
  name String
  address String
  province_id String
  district_id String
  commune_id String
  phone String
  allow_create_order Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /** Quan hệ với bảng provinces */
  province provinces @relation("WarehouseProvince", fields: [province_id], references: [id], onDelete: Restrict)  
  /** Quan hệ với bảng districts */
  district districts @relation("WarehouseDistrict", fields: [district_id], references: [id], onDelete: Restrict)
  /** Quan hệ với bảng communes */
  commune  communes  @relation("WarehouseCommune", fields: [commune_id],  references: [id], onDelete: Restrict)

  // Quan hệ ngược với products
  products products[]

  /** Quan hệ ngược với inventories */
  inventories Inventory[]
}



model tags {
  id    String  @id @default(cuid())
  name  String

  products products[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model categories { 
  id    String  @id @default(cuid())
  name  String
  
  products products[]
  voucherCategories VoucherCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Provider {
  id    String  @id @default(cuid())
  name  String
  phone String
  typeProvider String
  desc String?
  images String[]
  bank String? // ngân hàng nào
  bank_account String? //chủ tài khoản
  bank_number String? // số tài khoản


  address String //full địa chỉ

  province_id String
  district_id String
  commune_id String

  /** Quan hệ với bảng province */
  province provinces @relation("ProviderProvince", fields: [province_id], references: [id], onDelete: Restrict)  
  /** Quan hệ với bảng district */
  district districts @relation("ProviderDistrict", fields: [district_id], references: [id], onDelete: Restrict)
  /** Quan hệ với bảng commune */
  commune  communes  @relation("ProviderCommune", fields: [commune_id],  references: [id], onDelete: Restrict)
  
  // Quan hệ ngược với products
  products products[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model products {
  id                 String   @id @default(cuid())
  keyword            String
  name               String
  type               String
  description        String?
  images             String[]
  note               String?
  brand              String?
  material           String[]
  weight             String?
  category           String[]
  rating             Float    @default(0)
  reviewCount        Int      @default(0)
  
  is_published       Boolean  @default(false)
  is_hidden          Boolean  @default(false)
  is_new             Boolean  @default(false)
  is_featured        Boolean  @default(false)
  is_discount        Boolean  @default(false)

  
  // Dùng Json cho thuộc tính động
  product_attributes Json?
  
  last_import_price  Int      @default(0)
  price_at_counter   Int
  retail_price       Int
  sale_price         Int
  stock              Int      
  
  warehouse_id       String
  shop_id            String   @default("1")
  
  // Quan hệ
  warehouse          Warehouse    @relation(fields: [warehouse_id], references: [id])
  shop               shop         @relation(fields: [shop_id], references: [id])
  providers          Provider[]
  tags               tags[]
  categories         categories[]
  wishlist           Wishlist[]
  inventories        Inventory[]
  comments           comments[]
  /** Quan hệ ngược với ProductVariant */
  variants           ProductVariant[]
  /** Quan hệ ngược với CartItem */
  cartItems          CartItem[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([id, shop_id, warehouse_id])
}

model shop {
  id    String  @id @default(cuid())
  userId Int @unique
  user User @relation(fields: [userId], references: [id])
  email String @unique @default("shop@gmail.com")
  name  String
  phone String?
  typeProvider String?
  slug String @unique
  desc String?
  avatar_url String?
  bank String? // ngân hàng nào
  bank_account String? //chủ tài khoản
  bank_number String? // số tài khoản
  password String?
  refresh_token String?
  followersCount Int @default(0)


  address String? //full địa chỉ

  province_id String?
  district_id String?
  commune_id String?


  /** Quan hệ với bảng province */
  province provinces? @relation("ShopProvince", fields: [province_id], references: [id], onDelete: Restrict)  
  /** Quan hệ với bảng district */
  district districts? @relation("ShopDistrict", fields: [district_id], references: [id], onDelete: Restrict)
  /** Quan hệ với bảng commune */
  commune  communes?  @relation("ShopCommune", fields: [commune_id],  references: [id], onDelete: Restrict)
  
  // Quan hệ ngược với products
  products products[]
  //Quan hệ ngược với employer
  employer Employer[]
  //Quan hệ ngược với inventory
  inventory Inventory[]
  //Quan hệ ngược với FollowShop
  FollowShop FollowShop[]
  //quan hệ ngược với voucher
  Voucher Voucher[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  last_seen_at DateTime @default(now())

  @@index([id, userId])
}

model Employer {
  id        String      @id @default(cuid())
  userId Int @unique
  user User @relation(fields: [userId], references: [id])
  email     String   @unique @default("employer@gmail.com")
  name      String?
  age       Int?
  address   String?
  password  String @default("employer")
  refresh_token String?
  phone     String?
  salary     Int?
  avatar_url String?
  role      Role  @default(employer)

  shop_id String
  shop shop @relation(fields: [shop_id], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id, shop_id])
  @@index([userId])
}

model Inventory {
  id               String    @id @default(cuid())

  /** Quan hệ ngược với products */
  productId        String
  /** Quan hệ ngược với warehouse */
  warehouseId      String
  /** Quan hệ ngược với shop */
  shopId String

  /** Tồn kho thực */
  quantity         Int       
  /** Tồn kho đã đặt */
  reservedQuantity Int       @default(0)

  /** Trạng thái */
  status           InventoryStatus @default(ACTIVE)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  /** Quan hệ ngược với products */
  product          products   @relation(fields: [productId], references: [id])
  /** Quan hệ ngược với warehouse */
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  /** Quan hệ ngược với shop */
  shop shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, warehouseId, productId])
  @@index([id, productId, warehouseId, shopId])

}


model Wishlist {
  id        String    @id @default(cuid())
  userId    Int
  productId String
  /** Quan hệ với bảng products */
  product   products @relation(fields: [productId], references: [id])
  /** Quan hệ với bảng user */
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /** Mỗi user chỉ được thêm 1 sản phẩm vào wishlist */
  @@unique([userId, productId])
}


model comments {
  id        String   @id @default(cuid())
  productId String   
  userId    Int      
  content   String 
  images    String[]
  createdAt DateTime @default(now())
  /** Prisma tự cập nhật khi có thay đổi */
  updatedAt DateTime @updatedAt

  /** Quan hệ ngược với products */
  product   products @relation(fields: [productId], references: [id])
  /** Quan hệ ngược với user */
  user      User     @relation(fields: [userId], references: [id])

  @@index([productId, userId])
}


model Attribute {
  id String  @id @default(uuid())
  code String @unique
  type String


  values AttributeValue[]
}

model AttributeValue{
  id String @id @default(uuid())
  attributeId   String
  code String
  label String
  

  //Quan hệ với bảng Attributes
  Attribute Attribute @relation(fields: [attributeId], references:[id])

  variants VariantAttribute[]

}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  sku       String  @unique
  price     Int
  stock     Int

  /** Quan hệ với bảng products */
  product   products @relation(fields: [productId], references: [id])
  /** Quan hệ ngược với VariantAttribute */
  attrs     VariantAttribute[]
  /** Quan hệ ngược với CartItem */
  cartItems CartItem[]
}

model VariantAttribute {
  variantId        String
  attributeValueId String

  /** Quan hệ với bảng ProductVariant */
  variant          ProductVariant  @relation(fields: [variantId], references: [id])
  /** Quan hệ với bảng AttributeValue */
  attributeValue   AttributeValue  @relation(fields: [attributeValueId], references: [id])

  @@id([variantId, attributeValueId])
}


//Enum Cart Status
enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

model Cart {
  id        String     @id @default(uuid())
  /** Id của user, cùng kiểu Int với User.id */
  userId    Int?
  sessionId String?
  status    CartStatus @default(ACTIVE)

  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     CartItem[]

  user      User?      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
}


model CartItem {
  id               String          @id @default(uuid())
  cartId           String
  productId        String
  productVariantId String
  quantity         Int


  cart             Cart            @relation(fields: [cartId], references: [id])
  product          products        @relation(fields: [productId], references: [id])
  variant          ProductVariant  @relation(fields: [productVariantId], references: [id])

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([cartId, productVariantId])
}


model FollowShop {
  id String @id @default(uuid())
  userId Int
  shopId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, shopId])
  @@index([userId])
  @@index([shopId])
}

//người tạo ra voucher
enum VoucherProvider {
  SHOP
  ADMIN
}

//loại voucher là gì? 
enum VoucherType {
  FREESHIPPING
  DISCOUNT_MONEY
  DISCOUNT_PERCENT
}


//voucher áp dụng cho đâu
enum VoucherApplyType {
  ALL
  PRODUCT
  CATEGORY
}


model Voucher {
  id        String   @id @default(uuid())

  // ai tạo
  provider  VoucherProvider @default(ADMIN)
  shopId    String?

  // thông tin cơ bản
  code      String   @unique
  name      String

  type      VoucherType

  // giá trị giảm
  value     Int      // 10k hoặc 10 (%)
  maxValue  Int?     // cap cho percent

  // điều kiện áp dụng
  minOrderValue Int?

  // phạm vi áp dụng
  applyType VoucherApplyType @default(ALL)

  // số lượng
  quantity  Int?      @default(1)
  used      Int?      @default(0)

  // giới hạn user
  usageLimitPerUser Int?

  // freeshipping
  shippingDiscount Int?

  // trạng thái
  isActive  Boolean  @default(true)
  isPublic  Boolean  @default(true)

  // thời gian
  startTime DateTime
  endTime   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  shop shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  voucherProducts  VoucherProduct[]
  voucherCategories VoucherCategory[]
  usages           VoucherUsage[]
  OrderVoucher      OrderVoucher[]

  @@index([code])
  @@index([shopId])
  @@index([startTime, endTime])
}


//voucher áp dụng cho sản phẩm
model VoucherProduct {
  id         String @id @default(uuid())
  voucherId  String
  productId  String

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, productId])
}

//voucher cho ngành hàng
model VoucherCategory {
  id          String @id @default(uuid())
  voucherId   String
  categoryId  String

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  category categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([voucherId, categoryId])
}

//tracking voucher sử dụng
model VoucherUsage {
  id        String @id @default(uuid())

  userId    Int
  voucherId String

  usedCount Int @default(1)

  createdAt DateTime @default(now())

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

}


//voucher cho order
model OrderVoucher {
  id        String @id @default(uuid())

  orderId   String
  voucherId String

  discountAmount Int

  voucher Voucher @relation(fields: [voucherId], references: [id])

  @@index([orderId])
}